{
  "name": "AIJobs",
  "type": "object",
  "properties": {
    "topic_id": {
      "type": "string"
    },
    "topic_title": {
      "type": "string"
    },
    "client_id": {
      "type": "string",
      "description": "Reference to Clients ID"
    },
    "client": {
      "type": "string",
      "description": "Denormalized client business_name"
    },
    "job_type": {
      "type": "string",
      "enum": [
        "blog",
        "landing_page",
        "video_script",
        "social_series",
        "gbp_post",
        "email"
      ]
    },
    "prompt_input": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ],
      "default": "pending"
    },
    "output_reference": {
      "type": "string",
      "description": "ID of the resulting ContentAsset"
    },
    "error_message": {
      "type": "string"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional notes or description"
    }
  },
  "required": [
    "topic_id",
    "job_type",
    "client_id"
  ]
}