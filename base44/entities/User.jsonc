{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "client"
      ],
      "default": "client"
    },
    "company_name": {
      "type": "string",
      "description": "Optional: Name of the client's company"
    },
    "client_id": {
      "type": "string",
      "description": "Optional: Links to the Company or SalesLead entity for data scoping"
    }
  }
}