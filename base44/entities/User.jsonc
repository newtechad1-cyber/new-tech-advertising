{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "client",
        "staff",
        "reseller"
      ],
      "default": "client"
    },
    "company_id": {
      "type": "string",
      "description": "Relation to ClientCompanies entity"
    },
    "name": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}