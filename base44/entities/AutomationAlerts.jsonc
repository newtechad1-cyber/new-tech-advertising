{
  "name": "AutomationAlerts",
  "type": "object",
  "properties": {
    "automation_name": {
      "type": "string"
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "stuck_job",
        "failed_job",
        "error",
        "warning"
      ]
    },
    "message": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resolved"
      ],
      "default": "open"
    },
    "reference_id": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional notes or description"
    }
  },
  "required": [
    "automation_name",
    "issue_type",
    "message"
  ]
}