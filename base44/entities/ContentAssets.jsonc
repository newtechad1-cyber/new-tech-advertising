{
  "name": "ContentAssets",
  "type": "object",
  "properties": {
    "topic_id": {
      "type": "string"
    },
    "topic_title": {
      "type": "string"
    },
    "client_id": {
      "type": "string",
      "description": "Reference to Clients ID"
    },
    "client": {
      "type": "string",
      "description": "Denormalized client business_name"
    },
    "asset_type": {
      "type": "string",
      "enum": [
        "blog",
        "landing_page",
        "video_script",
        "social_series",
        "gbp_post",
        "email"
      ]
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "format": "markdown"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "needs_review",
        "ready_for_review",
        "approved",
        "rejected",
        "published"
      ],
      "default": "draft"
    },
    "published_url": {
      "type": "string"
    },
    "media_url": {
      "type": "string"
    },
    "video_url": {
      "type": "string"
    },
    "caption": {
      "type": "string"
    },
    "hashtags": {
      "type": "string"
    },
    "review_notes": {
      "type": "string"
    }
  },
  "required": [
    "topic_id",
    "asset_type",
    "client_id"
  ]
}