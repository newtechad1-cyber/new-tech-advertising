{
  "name": "CategoryInterpretationJob",
  "type": "object",
  "properties": {
    "session_id": { "type": "string" },
    "entry_id": { "type": "string" },
    "run_id": { "type": "string" },
    "attempt_number": { "type": "integer", "default": 1 },
    "interpretation_version": { "type": "integer" },
    "status": {
      "type": "string",
      "enum": ["processing", "completed", "failed"],
      "default": "processing"
    },
    "last_error": {
      "type": "string",
      "enum": [
        "ENTRY_NOT_FOUND", "SESSION_INELIGIBLE", "INVALID_AI_OUTPUT",
        "LLM_INVOCATION_FAILED", "CATEGORY_STAGING_FAILED"
      ]
    },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "session_id", "entry_id", "run_id", "attempt_number",
    "interpretation_version", "status", "started_at"
  ],
  "rls": { "create": false, "read": false, "update": false, "delete": false }
}